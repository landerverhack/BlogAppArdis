@page "/"

<PageTitle>ChatGPT</PageTitle>

<div class="cg-shell">
    <aside class="cg-sidebar">
        <div class="cg-sidebar-top">
            <button class="cg-icon-btn cg-logo" aria-label="Logo">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6" />
                    <path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
            </button>
            <button class="cg-icon-btn" aria-label="Close sidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.6" />
                    <line x1="9.5" y1="4" x2="9.5" y2="20" stroke="currentColor" stroke-width="1.6" />
                </svg>
            </button>
        </div>

        <nav class="cg-nav">
            <a class="cg-nav-item active" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                <span>New chat</span>
            </a>
            <a class="cg-nav-item" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6" /><line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>
                <span>Search chats</span>
            </a>
            <a class="cg-nav-item" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.6" /><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" /><path d="M21 15l-5-5-9 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                <span>Images</span>
            </a>
            <a class="cg-nav-item" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6" /><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6" /><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6" /><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6" /></svg>
                <span>Apps</span>
            </a>
            <a class="cg-nav-item" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6" /><path d="M21 21l-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><path d="M9 11l1.5-2.5L13 11l-1.5 2.5Z" stroke="currentColor" stroke-width="1.4" /></svg>
                <span>Deep research</span>
            </a>
        </nav>

        <div class="cg-sidebar-spacer"></div>

        <div class="cg-sidebar-bottom-links">
            <a class="cg-nav-item small" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" /><path d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-.8.4-1.3 1-1.3 1.7v.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><circle cx="12" cy="17" r="0.9" fill="currentColor" /></svg>
                <span>See plans and pricing</span>
            </a>
            <a class="cg-nav-item small" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6" /><path d="M19.4 13a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6V19a2 2 0 1 1-4 0v-.2a1.7 1.7 0 0 0-1.1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.6-1H3a2 2 0 1 1 0-4h.2a1.7 1.7 0 0 0 1.6-1.1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.9.3H9a1.7 1.7 0 0 0 1-1.6V3a2 2 0 1 1 4 0v.2a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.9V9a1.7 1.7 0 0 0 1.6 1H21a2 2 0 1 1 0 4h-.2a1.7 1.7 0 0 0-1.6 1Z" stroke="currentColor" stroke-width="1.2" /></svg>
                <span>Settings</span>
            </a>
            <a class="cg-nav-item small" href="/">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" /><path d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-.8.4-1.3 1-1.3 1.7v.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><circle cx="12" cy="17" r="0.9" fill="currentColor" /></svg>
                <span>Help</span>
            </a>
        </div>

        <div class="cg-divider"></div>

        <div class="cg-login-card">
            <p class="cg-login-title">Get responses tailored to you</p>
            <p class="cg-login-sub">Log in to get answers based on saved chats, plus create images and upload files.</p>
            <button class="cg-btn cg-btn-outline full">Log in</button>
        </div>
    </aside>

    <div class="cg-main">
        <header class="cg-header">
            <button class="cg-model-selector">
                <span>ChatGPT</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
            <div class="cg-header-actions">
                <button class="cg-btn cg-btn-primary">Log in</button>
                <button class="cg-btn cg-btn-outline">Sign up for free</button>
            </div>
        </header>

        <main class="cg-content">
            <div class="cg-center">
                <h1 class="cg-heading">Where should we begin?</h1>

                <div class="cg-composer">
                    <button class="cg-composer-icon" aria-label="Add files and more">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                    </button>

                    <div class="cg-composer-input" data-placeholder="Ask anything"></div>

                    <button class="cg-composer-icon" aria-label="Start dictation">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="9" y="3" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.6" /><path d="M5 11a7 7 0 0 0 14 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><line x1="12" y1="18" x2="12" y2="21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>
                    </button>

                    <button class="cg-voice-pill" aria-label="Start voice">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><line x1="4" y1="10" x2="4" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><line x1="9" y1="6" x2="9" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><line x1="14" y1="3" x2="14" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><line x1="19" y1="8" x2="19" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                        <span>Voice</span>
                    </button>
                </div>
            </div>

            <footer class="cg-footer">
                ChatGPT is AI. By using it, you agree to our <a href="/">Terms</a> &amp; <a href="/">Privacy Policy</a>. Chats may be reviewed and used to improve our AI models. <a href="/">Learn more</a>
            </footer>
        </main>
    </div>
</div>
